{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "App-data-scoped FS access — limits filesystem permissions to the application data directory to prevent arbitrary file access from a compromised renderer.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    { "identifier": "fs:allow-read-text-file", "allow": [{ "path": "$APPDATA/**" }] },
    { "identifier": "fs:allow-write-text-file", "allow": [{ "path": "$APPDATA/**" }] },
    { "identifier": "fs:allow-mkdir",           "allow": [{ "path": "$APPDATA/**" }] },
    { "identifier": "fs:allow-exists",          "allow": [{ "path": "$APPDATA/**" }] },
    { "identifier": "fs:allow-read-dir",        "allow": [{ "path": "$APPDATA/**" }] },
    { "identifier": "fs:allow-remove",          "allow": [{ "path": "$APPDATA/**" }] },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "http:default",
    "shell:allow-open",
    "updater:default"
  ]
}
