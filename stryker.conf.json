{
  "$schema": "https://json.schemastore.org/stryker.conf.json",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "incremental": true,
  "plugins": ["@stryker-mutator/vitest-runner", "@stryker-mutator/typescript-checker"],
  "checkers": ["typescript"],
  "mutate": [
    "services/codexService.ts",
    "services/dbMigration.ts",
    "services/commands/fuzzyScore.ts",
    "services/commands/palettePreferences.ts",
    "services/commands/commandBuilder.ts",
    "services/ai/hybridFallback.ts",
    "services/ai/providerFactory.ts",
    "services/ai/aiPolicy.ts",
    "services/ai/aiRetry.ts",
    "services/ai/inferenceGateway.ts",
    "services/help/helpDocRetrieval.ts",
    "services/localRagService.ts",
    "services/plotBoardService.ts",
    "services/sceneRevisionService.ts",
    "services/crossProjectSearchService.ts",
    "services/promptLibrary.ts",
    "services/duckdb/duckdbMigration.ts",
    "services/storage/idbCore.ts",
    "services/storage/idbKeyStore.ts",
    "services/storage/idbCodexStore.ts",
    "services/storage/idbSnapshotStore.ts",
    "services/storage/idbAssetStore.ts",
    "services/storage/idbProjectStore.ts",
    "features/project/aiThunkUtils.ts",
    "features/project/projectSelectors.ts",
    "features/project/projectSlice.ts",
    "features/project/sectionRestoreHelpers.ts",
    "features/proForge/proForgeSlice.ts",
    "hooks/useGlobalKeyboardShortcuts.ts",
    "hooks/useProForgeOrchestrator.ts",
    "hooks/useStoryCraftAI.ts",
    "app/listenerMiddleware.ts",
    "app/transientUiStore.ts",
    "services/aiProviderService.ts",
    "services/storage/storageEncryptionService.ts",
    "services/logger.ts",
    "services/collaborationService.ts",
    "services/i18nBootstrap.ts",
    "features/featureFlags/featureFlagsSlice.ts",
    "services/crossProjectIndexService.ts",
    "features/settings/accessibilitySchema.ts",
    "services/pluginRegistry.ts",
    "services/deepLinkService.ts",
    "services/voice/voiceCommandService.ts",
    "services/voice/vadEngine.ts",
    "services/voice/sttEngine.ts",
    "services/voice/wasmSttEngine.ts",
    "services/voice/sileroVadEngine.ts",
    "services/ai/webGpuDetectorService.ts",
    "services/ai/gpuResourceManager.ts",
    "services/localAiFacade.ts",
    "services/ai/deviceHealthService.ts",
    "services/ai/localEmbeddingService.ts",
    "services/ai/ecoModeService.ts",
    "services/ai/modelRecommendations.ts",
    "services/ai/aiRetry.ts",
    "services/ai/aiPolicy.ts",
    "services/ai/hybridFallback.ts",
    "services/ai/inferenceGateway.ts",
    "packages/ai-core/src/index.ts",
    "packages/ai-core/src/tabLeaderElection.ts",
    "packages/ai-core/src/webllmOptimizer.ts",
    "packages/ai-core/src/onnxRuntimeEngine.ts",
    "packages/ai-core/src/webnnBridge.ts",
    "services/ai/adaptiveAiEngine.ts",
    "services/ai/computeShaderFactory.ts",
    "services/ai/localAiDeviceProfiler.ts",
    "hooks/useAdaptiveAi.ts",
    "features/progressTracker/progressTrackerSlice.ts"
  ],
  "thresholds": {
    "high": 85,
    "low": 70,
    "break": 75
  },
  "reporters": ["progress", "clear-text", "html", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "timeoutMS": 180000,
  "concurrency": 2,
  "warnings": {
    "slow": false
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/playwright-report/**",
    "**/storybook-static/**"
  ]
}
