# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# pnpm store (should never be committed)
.pnpm-store/

node_modules
dist
dist-ssr
*.local
coverage/
reports/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/problemMatchers.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Tauri build output
src-tauri/target/
.env

test-results/

# Playwright default output dir (when reporter dir differs from tests/e2e/html-report)
playwright-report/

# CI Analyzer artifacts (downloaded from GitHub Actions)
artifacts/

# Playwright HTML report / junit (generated locally or in CI artifacts)
tests/e2e/html-report/
tests/e2e/results/

# Storybook static build output
storybook-static/

# Storybook HTML story files (generated during build)
components/**/*.html
app/**/*.html
hooks/**/*.html
features/**/*.html

# Graphify — solo policy: only GRAPH_REPORT.md is committed; regenerate locally via pnpm run graphify:update
graphify-out/*
!graphify-out/GRAPH_REPORT.md
graphify-out/cache/
graphify-out/manifest.json
graphify-out/cost.json

# Runtime i18n: only bundle.json is deployed (sources live in locales/<lang>/)
public/locales/*/*.json
!public/locales/*/bundle.json

# Claude Code local config and Lighthouse CI results
.claude/
.lighthouseci/

# Continue IDE config (local dev only)
.continue/

# CodeGraph — solo policy: only CODEGRAPH_REPORT.md committed; DB stays local
.codegraph/*
!.codegraph/CODEGRAPH_REPORT.md
.codegraph/codegraph.db-shm
.codegraph/codegraph.db-wal
voice-spike/

# Signing keys, certificates, and secrets — NEVER commit
*.key
*.key.pub
*.pem
*.p12
*.pfx
*.cer
*.crt
*.der
.storycraft-*
~/

