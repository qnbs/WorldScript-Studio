{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.base.schema.json",
  "name": "StoryCraft Studio",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "1.1.0"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "1.1.0"
    }
  },
  "onCreateCommand": "corepack enable && corepack prepare pnpm@10.33.0 --activate",
  "postCreateCommand": "pnpm install --frozen-lockfile || (echo '⚠️ pnpm install failed — check lockfile' && exit 1) && pnpm run i18n:bundle || echo '⚠️ i18n:bundle failed — run manually' && npx playwright install chromium || echo '⚠️ playwright install failed — run manually' && pnpm run prepare || echo '⚠️ prepare failed — check git hooks' && npm install -g @anthropic-ai/claude-code 2>/dev/null || true && (pnpm run lint && pnpm run typecheck && echo '✅ Quality gate: lint + typecheck OK') || echo '⚠️ Quality gate has issues — run: pnpm run lint && pnpm run typecheck'",
  "postStartCommand": "node --version && pnpm --version && rustc --version 2>/dev/null || true && gh run list --limit 3 --json status,conclusion,name 2>/dev/null | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const r=JSON.parse(d);r.forEach(x=>console.log(x.conclusion==='success'?'✅':'❌',x.name,x.status))}catch{}})\" || true",
  "postAttachCommand": "echo '✅ StoryCraft Studio ready — see docs/SPRINT-HANDOFF-2026-05-30-codespace-uplift.md for session context. Run: pnpm run dev'",
  "forwardPorts": [3000, 4173, 6006, 9323],
  "portsAttributes": {
    "3000": {
      "label": "Vite Dev Server",
      "onAutoForward": "openBrowserOnce"
    },
    "4173": {
      "label": "Vite Preview",
      "onAutoForward": "notify"
    },
    "6006": {
      "label": "Storybook",
      "onAutoForward": "notify"
    },
    "9323": {
      "label": "Playwright Report",
      "onAutoForward": "notify"
    }
  },
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=8192",
    "CI": "true",
    "PLAYWRIGHT_BROWSERS_PATH": "/usr/local/playwright",
    "VITE_BASE": "/",
    "RUN_MOBILE_E2E": "0",
    "VITEST_MAX_WORKERS": "1"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/usr/local/cargo/bin"
  },
  "hostRequirements": {
    "cpus": 8,
    "memory": "16gb",
    "storage": "32gb"
  },
  "mounts": [
    "source=storycraft-pnpm-store,target=/home/vscode/.local/share/pnpm/store,type=volume",
    "source=storycraft-cargo-cache,target=/usr/local/cargo/registry,type=volume",
    "source=storycraft-rustup-cache,target=/usr/local/rustup,type=volume"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash",
            "icon": "terminal-bash",
            "env": {
              "STARSHIP_CONFIG": "/workspaces/${localWorkspaceFolderBasename}/.devcontainer/starship.toml"
            }
          }
        },
        "terminal.integrated.env.linux": {
          "STARSHIP_CONFIG": "/workspaces/${localWorkspaceFolderBasename}/.devcontainer/starship.toml"
        },
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnPaste": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports.biome": "explicit",
          "quickfix.biome": "explicit"
        },
        "editor.rulers": [100],
        "editor.wordWrap": "off",
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.trimAutoWhitespace": true,
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs": "active",
        "editor.stickyScroll.enabled": true,
        "editor.minimap.enabled": false,
        "editor.linkedEditing": true,
        "editor.inlineSuggest.enabled": true,
        "files.encoding": "utf8",
        "files.eol": "\n",
        "files.insertFinalNewline": true,
        "files.trimTrailingWhitespace": true,
        "files.associations": {
          "*.css": "tailwindcss",
          "devcontainer.json": "jsonc",
          "*.jsonc": "jsonc"
        },
        "files.exclude": {
          "**/.git": true,
          "**/.svn": true,
          "**/.hg": true,
          "**/CVS": true,
          "**/.DS_Store": true,
          "**/node_modules": true,
          "**/dist": true,
          "**/coverage": true,
          "**/storybook-static": true,
          "**/playwright-report": true,
          "**/test-results": true
        },
        "search.exclude": {
          "**/node_modules": true,
          "**/dist": true,
          "**/coverage": true,
          "**/.git": true,
          "**/pnpm-lock.yaml": true,
          "**/storybook-static": true,
          "**/playwright-report": true,
          "**/test-results": true,
          "**/graphify-out": true,
          "**/src-tauri/target": true,
          "pnpm-lock.yaml": true
        },
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "typescript.preferences.importModuleSpecifier": "non-relative",
        "typescript.preferences.importModuleSpecifierEnding": "js",
        "typescript.suggest.autoImports": true,
        "typescript.updateImportsOnFileMove.enabled": "always",
        "typescript.inlayHints.parameterNames.enabled": "all",
        "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
        "typescript.inlayHints.variableTypes.enabled": true,
        "tailwindCSS.includeLanguages": {
          "typescript": "javascript",
          "typescriptreact": "javascript"
        },
        "tailwindCSS.experimental.classRegex": [
          ["class:\\s*?[\"']([^\"']*)[\"']", "([^\"'{}\\s]*)"]
        ],
        "emmet.includeLanguages": {
          "typescriptreact": "html",
          "javascriptreact": "html"
        },
        "git.autofetch": true,
        "git.confirmSync": false,
        "git.enableSmartCommit": true,
        "git.postCommitCommand": "push",
        "scm.defaultViewMode": "tree",
        "vitest.enable": true,
        "vitest.commandLine": "pnpm exec vitest",
        "accessibility.signals.soundsVolume": 0,
        "extensions.autoUpdate": "onlyEnabledExtensions",
        "extensions.ignoreRecommendations": true,
        "telemetry.telemetryLevel": "off",
        "workbench.enableExperiments": false,
        "workbench.trustedDomains.management": {
          "enabled": true
        }
      },
      "extensions": [
        "biomejs.biome",
        "bradlc.vscode-tailwindcss",
        "GitHub.copilot",
        "GitHub.vscode-pull-request-github",
        "vitest.explorer",
        "ms-playwright.playwright",
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker",
        "usernamehw.errorlens",
        "sonarsource.sonarlint-vscode",
        "antfu.iconify",
        "firefox-devtools.react-devtools",
        "lokalise.i18n-ally",
        "rust-lang.rust-analyzer",
        "tauri-apps.tauri-vscode",
        "serayuzgur.crates",
        "ms-azuretools.vscode-docker",
        "pkief.material-icon-theme",
        "moonshot-ai.kimi-code"
      ]
    },
    "codespaces": {
      "openFiles": ["docs/SPRINT-HANDOFF-2026-05-30-codespace-uplift.md", "README.md"]
    }
  }
}
