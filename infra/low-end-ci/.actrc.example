# Copy to ~/.actrc (adjust paths if HOME differs)
# Ubuntu 20.04 + WorldScript Studio — Node 22 medium image, bind mounts, RAM cap

-P ubuntu-latest=catthehacker/ubuntu:act-22.04
--container-architecture linux/amd64
--bind
--env NODE_OPTIONS=--max-old-space-size=1536
--env PNPM_STORE_DIR=/pnpm-store
--secret-file ~/worldscript-ci/act.secrets
--artifact-server-path ~/worldscript-ci/cache/act/artifacts
