# WorldScript Studio — low-end local CI (append to ~/.bashrc)
export WORLDSCRIPT_CI_HOME="${HOME}/worldscript-ci"
export PNPM_STORE_DIR="${WORLDSCRIPT_CI_HOME}/cache/pnpm-store"
export WORLDSCRIPT_REPO="${HOME}/githubcursor/WorldScript-Studio"
export PATH="${WORLDSCRIPT_REPO}/infra/low-end-ci/scripts:${PATH}"

alias sc-ci='cd "${WORLDSCRIPT_REPO}" && ci-quick.sh'
alias sc-ci-unit='cd "${WORLDSCRIPT_REPO}" && ci-quick.sh --unit'
alias sc-ci-cov='cd "${WORLDSCRIPT_REPO}" && ci-quick.sh --unit --coverage'
alias sc-act='cd "${WORLDSCRIPT_REPO}" && ci-act-sequential.sh pull_request'
alias sc-act-full='cd "${WORLDSCRIPT_REPO}" && ci-act-sequential.sh pull_request --with-storybook --e2e-chromium-only'
alias sc-eco-on='ci-eco-start.sh'
alias sc-eco-off='ci-eco-stop.sh --prune'
alias sc-status='ci-status.sh'
alias sc-backup='backup-ci.sh'
alias sc-mirror-up='cd "${WORLDSCRIPT_REPO}" && mirror-github-to-forgejo.sh --direction pull-from-github'
alias sc-mirror-gh='cd "${WORLDSCRIPT_REPO}" && mirror-github-to-forgejo.sh --direction push-to-github'
