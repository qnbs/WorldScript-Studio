{
  "name": "storycraft-studio",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "predev": "node scripts/sync-sw-version.mjs && node scripts/build-i18n.mjs",
    "dev": "vite",
    "dev:turbo": "turbo run dev --parallel",
    "prebuild": "node scripts/sync-sw-version.mjs && node scripts/build-i18n.mjs",
    "i18n:bundle": "node scripts/build-i18n.mjs",
    "i18n:check": "node scripts/check-i18n-keys.mjs && node scripts/build-i18n.mjs && node scripts/content-guard.mjs",
    "content:guard": "node scripts/content-guard.mjs",
    "graphify": "node scripts/graphify-cli.mjs",
    "graphify:install": "node scripts/graphify-cli.mjs install",
    "graphify:update": "node scripts/graphify-cli.mjs update .",
    "graphify:bootstrap": "node scripts/graphify-bootstrap.mjs",
    "graphify:hooks": "node scripts/graphify-cli.mjs hook install",
    "graphify:status": "node scripts/graphify-cli.mjs hook status",
    "build": "vite build",
    "build:turbo": "turbo run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:turbo": "turbo run typecheck",
    "lhci:assert": "lhci autorun --upload.target=temporary-public-storage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "biome lint --max-diagnostics=200 --error-on-warnings",
    "mutation": "stryker run",
    "lint:turbo": "turbo run lint",
    "lint:fix": "biome check --write",
    "format": "biome format --write .",
    "test": "vitest",
    "test:turbo": "turbo run test",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node -e \"if (process.env.CI !== 'true') { console.error('E2E tests are CI-only. Set CI=true or run via GitHub Actions.'); process.exit(1); }\" && playwright test",
    "test:e2e:ui": "node -e \"if (process.env.CI !== 'true') { console.error('E2E tests are CI-only. Set CI=true or run via GitHub Actions.'); process.exit(1); }\" && playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "analyze": "ANALYZE=true vite build",
    "bundle:budget": "node scripts/check-bundle-budget.mjs --max-kb 7000",
    "dev:tauri": "tauri dev"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/openai": "^3.0.64",
    "@ai-sdk/react": "^3.0.186",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@domain/ai-core": "workspace:*",
    "@domain/ui": "workspace:*",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@google/genai": "^2.3.0",
    "@reduxjs/toolkit": "^2.2.6",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "ai": "^6.0.184",
    "diff-match-patch": "^1.0.5",
    "docx": "^9.6.1",
    "dompurify": "^3.4.4",
    "driver.js": "^1.4.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lz-string": "^1.5.0",
    "mammoth": "^1.12.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-force-graph-2d": "^1.29.1",
    "react-redux": "^9.3.0",
    "recharts": "^3.8.1",
    "redux-undo": "^1.1.0",
    "uuid": "14",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.30",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@biomejs/biome": "^2.4.15",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/react": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@stryker-mutator/core": "^9.2.0",
    "@stryker-mutator/vitest-runner": "^9.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "rollup-plugin-visualizer": "^7.0.1",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "turbo": "^2.9.14",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.5",
    "y-protocols": "^1.0.7"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3",
      "chrome-launcher": "^1.2.1",
      "tmp": "^0.2.5",
      "@xmldom/xmldom": ">=0.8.13",
      "protobufjs": ">=7.5.6",
      "axios": ">=1.15.2",
      "basic-ftp": ">=5.3.1",
      "fast-uri": ">=3.1.2",
      "ip-address": ">=10.1.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "vite-plugin-pwa>vite": "8"
      }
    },
    "onlyBuiltDependencies": [
      "@google/genai",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npm exec -- lint-staged"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  }
}
