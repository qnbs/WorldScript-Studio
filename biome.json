{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "maxSize": 5000000,
    "includes": [
      "**",
      "!!**/dist",
      "!!**/node_modules",
      "!!**/.storybook",
      "!!**/backend",
      "!!**/src-tauri",
      "!!**/public/sw.js",
      "!!**/coverage",
      "!!**/playwright-report",
      "!!**/test-results",
      "!!**/reports",
      "!!**/storybook-static",
      "!!**/graphify-out",
      "!!**/.codegraph",
      "!!**/packages/collab-transport/src/y-webrtc.js",
      "!!**/packages/collab-transport/src/y-webrtc.d.ts",
      "!!**/packages/collab-transport/src/crypto.d.ts",
      "!!**/packages/collab-transport/src/crypto.js"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "error"
      },
      "complexity": {
        "noForEach": "off",
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": {
            "maxAllowedComplexity": 50
          }
        },
        "useLiteralKeys": "off",
        "useOptionalChain": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noArrayIndexKey": "error",
        "noConsole": {
          "level": "error",
          "options": {
            "allow": ["warn", "error", "group", "groupEnd", "groupCollapsed"]
          }
        }
      },
      "a11y": {
        "useKeyWithClickEvents": "error",
        "noSvgWithoutTitle": "off",
        "useButtonType": "error",
        "noLabelWithoutControl": "error",
        "useSemanticElements": "error",
        "useAriaPropsForRole": "error",
        "useAriaPropsSupportedByRole": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "security": {
        "noDangerouslySetInnerHtml": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["scripts/**/*.mjs", "scripts/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "style": {
            "useTemplate": "off"
          }
        }
      }
    },
    {
      "includes": ["services/logger.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["tests/**/*.ts", "tests/**/*.tsx"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": [
        "components/mind-map/**/*.tsx",
        "components/scene-board/ConnectionLayer.tsx",
        "components/scene-board/PlotCanvas.tsx",
        "components/scene-board/ConnectionToolbar.tsx",
        "components/scene-board/SceneCard.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          }
        }
      }
    }
  ]
}
